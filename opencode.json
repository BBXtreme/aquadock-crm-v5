{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "write": "ask"
  },
  "model": "anthropic/claude-sonnet-4-5",
  "lsp": true,
  "mcp": {
    "xai-docs": {
      "type": "remote",
      "url": "https://docs.x.ai/api/mcp",
      "enabled": true
    }
  },
  "plugin": [
    "opencode-vercel",
    "opencode-github",
    "opencode-changelog"
  ]
}