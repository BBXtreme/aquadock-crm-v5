# ------------------------------------------------------------------------------
# AquaDock CRM v5 — environment template
#
# Copy to `.env.local` and replace placeholders. Never commit `.env.local`.
# Docs: README.md, docs/production-deploy.md, docs/vercel-production.md
# ------------------------------------------------------------------------------

# --- Required: Supabase (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# --- Optional: server-only Supabase (bypasses RLS; never expose to the browser) ---
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# Also used server-side for preferred signed download URLs (`getCommentAttachmentSignedUrl`) and Storage
# cleanup on attachment delete. Needed for `/api/comment-attachments/upload` (preferred path for Storage
# + metadata). Without it, UI falls back to browser Storage upload — ensure Storage policies on `comment-files`
# allow your session.

# --- Optional: canonical site URL (password recovery, redirects) ---
# Local: http://localhost:3000 — Production: https://your-domain.example
# SITE_URL=
# NEXT_PUBLIC_SITE_URL=

# --- Optional: UI version label (falls back to package version if unset) ---
# NEXT_PUBLIC_APP_VERSION=0.0.0

# --- Optional: Brevo REST (docs/BREVO_SDK.md) — use xkeysib-… API keys, not SMTP keys ---
# BREVO_API_KEY=
# BREVO_SENDER_NAME=
# BREVO_SENDER_EMAIL=

# --- Optional: Vercel AI Gateway + company/contact enrichment ---
# AI_GATEWAY_API_KEY=
# AI_ENRICHMENT_XAI_API_KEY=
# AI_ENRICHMENT_GROK_MODEL=xai/grok-4.3
# AI_ENRICHMENT_DAILY_LIMIT_DEFAULT=

# --- Optional: semantic search (defaults; per-user overrides in user_settings) ---
# EMBEDDING_PROVIDER=gateway
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=          # required when EMBEDDING_PROVIDER=openai (direct OpenAI embeddings)

# --- Optional: companies list/search Phase 1 quick wins
# (docs/perf/companies-search-phase1.md)
# Flags default to ON when NODE_ENV=development, OFF otherwise.
# Set explicitly to "true"/"1" or "false"/"0" to override.
# COMPANIES_P1_EMBED_CACHE_ENABLED=true            # query-embedding TTL cache (7 min)
# COMPANIES_P1_TWO_PHASE_HYBRID_ENABLED=true       # rank IDs first, fetch page rows only
# COMPANIES_P1_RANKED_IDS_CACHE_ENABLED=true       # shared ranked IDs between search + nav-ids (90 s)
# COMPANIES_P1_LEXICAL_FASTPATH_ENABLED=true       # skip embedding + RPC for queries < 3 chars
# COMPANIES_P1_PERF_LOGS_ENABLED=true              # emit [companies-p1] timing logs

# --- Optional: companies list/search Phase 2 umbrella flags
# (docs/perf/phase2-entry-criteria.md, .cursor/plans/aquadock_crm_phase_2_performance_plan_*)
# Default to ON when NODE_ENV=development, OFF in production / test.
# Flip on in production only after the Phase 2 entry criteria are green for 7+ days.
# COMPANIES_P2_READS_ENABLED=true                  # companies_stats() RPC, Server-Timing, perf-events
# NEXT_PUBLIC_COMPANIES_P2_READS_ENABLED=true      # client-visible companion (browser bundle); keep in sync
# COMPANIES_P2_WRITES_ENABLED=true                 # generation token, after() for ownership audit, CRMForm server action

# --- Optional: async xAI Batch worker (poll route + ai_batch_jobs table) ---
# XAI_API_KEY=
# CRON_SECRET=             # or AI_BATCH_WORKER_SECRET — secures POST /api/internal/ai-batch/worker

# Onboarding / notification emails use the same per-user SMTP as Settings (user_settings.smtp_config);
# configure SMTP under Settings for at least one admin account — no separate SMTP_* env vars.

# On Vercel, VERCEL_URL / VERCEL_ENV are injected automatically — no entry needed here.

# --- Optional: Playwright E2E ---
# Local: values below go in .env.local (this file is only a template). playwright.config.ts uses
# loadEnvConfig(@next/env) so the Playwright Node process sees them without `export` in the shell.
# GitHub: E2E_USER_EMAIL + E2E_USER_PASSWORD = repository *secrets* (workflow uses secrets.E2E_*).
#         NEXT_PUBLIC_SUPABASE_* = Actions *variables* (not secrets) for the client bundle in CI.
# Run `pnpm build` before `pnpm e2e` (or let Playwright start next start). Use a real Supabase Auth user;
# set password in the Supabase dashboard. User must not be stuck on /access-pending or auth tests skip.
# Smoke E2E tests do not need E2E_*.
# E2E_BASE_URL=http://127.0.0.1:3000
# E2E_USER_EMAIL=your+ci@example.com
# E2E_USER_PASSWORD=your-secure-test-password
