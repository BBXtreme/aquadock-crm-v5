{
  // macOS: load login profile so nvm/Volta from ~/.zprofile applies (fixes Node 22 vs .nvmrc 24 in pnpm).
  "terminal.integrated.profiles.osx": {
    "zsh (login)": {
      "path": "/bin/zsh",
      "args": ["-l"],
      "icon": "terminal"
    }
  },
  "terminal.integrated.defaultProfile.osx": "zsh (login)",
  // Cursor often inherits a PATH with Homebrew Node before zsh/nvm run; prepending nvm fixes `pnpm` engine checks.
  // After `nvm install 24`, update the folder if the patch version changes (e.g. v24.15.0 → v24.16.0).
  "terminal.integrated.env.osx": {
    "PATH": "${env:HOME}/.nvm/versions/node/v24.15.0/bin:${env:PATH}"
  },

  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit",
    "source.organizeImports.biome": "explicit"
  },

  // TypeScript & Import preferences (updated to non-deprecated keys)
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "js/ts.preferences.importModuleSpecifierEnding": "minimal",
  "js/ts.tsdk.path": "node_modules/typescript/lib",

  // Tailwind CSS IntelliSense (important for Tailwind 4 + cn/cva)
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
    ["cn\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
  ],
  "files.associations": {
    "*.css": "tailwindcss"
  },

  // Error display improvements
  "errorLens.enabled": true,
  "errorLens.delay": 300,

  // Biome specific
  "biome.enabled": true,
  "biome.requireConfiguration": false,
  "cSpell.words": [
    "Adresse",
    "Firmendaten"
  ],
  "git.ignoreLimitWarning": true
}
