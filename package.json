  "scripts": {
    "supabase:types": "npx --yes supabase gen types typescript --project-id bqsdrmlyctqxxflhhqbr --schema public > src/types/supabase.ts",
    "dev": "NODE_OPTIONS=\"--max-old-space-size=8192\" next dev",
    "dev:large": "NODE_OPTIONS=\"--max-old-space-size=12288\" next dev",
    "build": "NODE_OPTIONS=\"--max-old-space-size=8192\" next build",
    "build:large": "NODE_OPTIONS=\"--max-old-space-size=12288\" next build",
    "start": "next start",
    "lint": "biome lint",
    "pre-commit": "lint-staged",
    "format": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write --unsafe",
    "check:quick": "biome check --write --max-diagnostics=50",
    "typecheck": "tsc --noEmit --pretty",
    "messages:validate": "node scripts/validate-message-keys.mjs",
    "backfill:user-id": "node scripts/backfill-user-id-from-created-by.mjs",
    "prepare": "husky",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:ci": "playwright test",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc}": [
      "biome check --files-ignore-unknown=true --no-errors-on-unmatched --write"
    ]
