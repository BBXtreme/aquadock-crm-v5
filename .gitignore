# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# Playwright (e2e)
/test-results/
/playwright-report/
/blob-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.sh

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Cursor agent instrumentation (NDJSON); do not commit
.cursor/debug*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example
.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Aider configuration
.aider.conf.yml
.aider*
aider*.md
# Tracked contributor doc (filename can match aider*.md on case-insensitive volumes).
!docs/AIDER-RULES.md
.env*.local
